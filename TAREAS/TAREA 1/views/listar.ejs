<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lista de Libros</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      padding: 40px;
      background-color: #f4f7f6;
      margin: 0;
    }

    h2 {
      text-align: center;
      color: #2c3e50;
      margin-bottom: 30px;
    }

    .table-container {
      max-width: 1000px;
      margin: 0 auto;
      background-color: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      padding: 15px;
      text-align: left;
      border-bottom: 1px solid #eee;
    }

    th {
      background-color: #1e0a74;
      color: white;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 14px;
    }

    tr:hover {
      background-color: #f9f9f9;
    }

    .actions {
      display: flex;
      gap: 10px;
    }

    .btn-edit {
      color: #007BFF;
      font-weight: bold;
      text-decoration: none;
    }

    .btn-delete {
      color: #dc3545;
      font-weight: bold;
      text-decoration: none;
    }

    .btn-edit:hover, .btn-delete:hover {
      text-decoration: underline;
    }

    .add-button-container {
      text-align: center;
      margin-top: 30px;
    }

    .add-button {
      display: inline-block;
      padding: 12px 25px;
      background-color: #322ce7;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      transition: background-color 0.3s;
    }

    .add-button:hover {
      background-color: #3c65ed;
    }
  </style>
</head>
<body>
  <h2>Gestión de Biblioteca</h2>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Título</th>
          <th>Autor</th>
          <th>Precio</th>
          <th>Categoría</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% libros.forEach(item => { %>
        <tr>
          <td><%= item.titulo %></td>
          <td><%= item.autor %></td>
          <td>$<%= item.precio %></td>
          <td><%= item.categoria %></td>
          <td class="actions">
            <a href="/edit/<%= item.id %>" class="btn-edit">Editar</a>
            <a href="/delete/<%= item.id %>" class="btn-delete" onclick="return confirm('¿Estás seguro?')">Eliminar</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="add-button-container">
    <a class="add-button" href="/create">Añadir Nuevo Libro</a>
  </div>
</body>
</html>