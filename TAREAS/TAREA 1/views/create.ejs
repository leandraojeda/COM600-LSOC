<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Agregar Libro</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f4f7f6;
      margin: 0;
      padding: 40px 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    form {
      background-color: #ffffff;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      width: 100%;
      max-width: 400px;
    }
    h2 { text-align: center; margin-bottom: 25px; color: #2c3e50; }
    label { display: block; margin-bottom: 8px; font-weight: 600; color: #555; }
    input {
      width: 100%;
      padding: 12px;
      margin-bottom: 20px;
      border: 1px solid #ddd;
      border-radius: 6px;
    }
    /* Estilo para el botón de envío */
    .btn-submit {
      width: 100%;
      padding: 12px;
      background-color: #1e0a74;
      border: none;
      color: white;
      font-size: 16px;
      font-weight: bold;
      border-radius: 6px;
      cursor: pointer;
      margin-bottom: 10px;
    }
    /* Estilo para el botón de volver (enlace) */
    .btn-link {
      display: block;
      width: 100%;
      padding: 12px;
      background-color: #4CAF50; /* Verde para diferenciar */
      color: white !important;
      text-align: center;
      text-decoration: none;
      font-size: 16px;
      font-weight: bold;
      border-radius: 6px;
    }
    .btn-link:hover { background-color: #45a049; }
    .boton-volver { margin-top: 10px; }
  </style>
</head>
<body>

  <form action="/libros/create" method="POST">
    <h2>Agregar Nuevo Libro</h2>

    <label for="titulo">Título</label>
    <input type="text" id="titulo" name="titulo" required />

    <label for="autor">Autor</label>
    <input type="text" id="autor" name="autor" required />

    <label for="precio">Precio</label>
    <input type="number" id="precio" name="precio" step="0.01" min="0" required />

    <label for="categoria">Categoría</label>
    <input type="text" id="categoria" name="categoria" required />

    <button type="submit" class="btn-submit">Guardar Libro</button>
    
    <div class="boton-volver">
      <a href="/listar" class="btn-link">Volver</a>
    </div>
  </form>

</body>
</html>